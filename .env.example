# Copy this file to ".env" (same folder) and fill in your real values.
# Required for Exercises 1, 3, and 4. Exercise 2 needs no Azure setup.
# See README.md for the full step-by-step Azure OpenAI walkthrough.
#
# NOTE: model names below are examples only. Azure has been retiring
# non-reasoning models (gpt-4o, gpt-4o-mini, gpt-4.1, gpt-4.1-mini) faster
# than their published timelines throughout 2026 — check Azure AI Foundry's
# deployment screen for what's actually deployable in your region before
# naming your deployments. The exercise scripts adapt automatically to
# whichever model type (reasoning or non-reasoning) you end up with.
#
# NEVER commit the real .env file to source control.

AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-10-21

# Exercise 3 (Model Comparison) needs BOTH deployments below.
# Exercises 1 and 4 only use AZURE_OPENAI_DEPLOYMENT_MINI.
AZURE_OPENAI_DEPLOYMENT_MINI=mini-deploy
AZURE_OPENAI_DEPLOYMENT_GPT4O=large-deploy
